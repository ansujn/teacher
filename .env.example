# ─────────────────────────────────────────────────────────────
# Required: Postgres connection string
# ─────────────────────────────────────────────────────────────
# Works with Neon, Vercel Postgres, Supabase, Railway, or any
# other hosted Postgres. For Neon, copy the "pooled" connection
# string (it ends with ?sslmode=require).
#
# Example: postgresql://user:pass@host/dbname?sslmode=require
DATABASE_URL=

# ─────────────────────────────────────────────────────────────
# Required: NextAuth session secret
# ─────────────────────────────────────────────────────────────
# Generate with: openssl rand -base64 32
AUTH_SECRET=

# Optional — only needed if Vercel can't infer the host (rare)
# AUTH_TRUST_HOST=true
# NEXTAUTH_URL=https://your-app.vercel.app

# ─────────────────────────────────────────────────────────────
# Used by prisma/seed.ts for the initial admin account
# ─────────────────────────────────────────────────────────────
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=change-me

# ─────────────────────────────────────────────────────────────
# Optional — protects /api/seed so it can't be called publicly
# ─────────────────────────────────────────────────────────────
SEED_SECRET=
